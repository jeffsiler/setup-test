<Window x:Class="TrimbleBatteryMonitor.Views.StatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TrimbleBatteryMonitor.Views"
        Title="Trimble Battery Monitor"
        Height="720"
        Width="900"
        MinHeight="560"
        MinWidth="720"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Settings" Click="SettingsMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="Minimize to _tray" Click="MinimizeMenuItem_Click"/>
                <MenuItem Header="E_xit" Click="ExitMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Refresh" Click="RefreshButton_Click"/>
            </MenuItem>
        </Menu>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="220"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource CardBrush}"
                    Padding="20"
                    CornerRadius="8"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Current Battery Status"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock x:Name="CurrentStatusText"
                                   Margin="0,10,0,0"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock x:Name="AcStatusText"
                                   Margin="0,8,0,0"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>
                        <TextBlock x:Name="TimeRemainingText"
                                   Margin="0,4,0,0"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Width="220" VerticalAlignment="Center">
                        <TextBlock Text="Charge level"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,0,0,6"/>
                        <ProgressBar x:Name="ChargeProgressBar"
                                     Height="28"
                                     Minimum="0"
                                     Maximum="100"/>
                        <TextBlock x:Name="ChargePercentLabel"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ItemsControl x:Name="BatteryCardsPanel"
                          Grid.Row="1"
                          Margin="0,0,0,12">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBrush}"
                                BorderBrush="#DDDDDD"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,12,12"
                                Width="260">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="{Binding Detail}"
                                           Margin="0,6,0,8"
                                           Foreground="{StaticResource MutedBrush}"
                                           TextWrapping="Wrap"/>
                                <ProgressBar Value="{Binding ChargePercent}"
                                             Minimum="0"
                                             Maximum="100"
                                             Height="16"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <views:BatteryChartControl x:Name="ChargeChart"
                                       Grid.Row="2"
                                       Margin="0,0,0,12"/>

            <TextBlock Grid.Row="3"
                       Text="History (last 24 hours)"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"
                       Foreground="{StaticResource TextBrush}"/>

            <DataGrid x:Name="HistoryGrid"
                      Grid.Row="4"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      Background="{StaticResource CardBrush}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Time (UTC)" Binding="{Binding TimestampUtc, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="160"/>
                    <DataGridTextColumn Header="Battery" Binding="{Binding BatteryName}" Width="140"/>
                    <DataGridTextColumn Header="Charge %" Binding="{Binding ChargePercent}" Width="90"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="110"/>
                    <DataGridTextColumn Header="AC" Binding="{Binding IsAcConnected}" Width="60"/>
                    <DataGridTextColumn Header="Time Left" Binding="{Binding TimeRemainingDisplay}" Width="100"/>
                    <DataGridTextColumn Header="Device ID" Binding="{Binding DeviceId}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </DockPanel>
</Window>
