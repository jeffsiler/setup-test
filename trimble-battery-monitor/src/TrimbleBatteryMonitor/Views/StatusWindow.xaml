<Window x:Class="TrimbleBatteryMonitor.Views.StatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Trimble Battery Monitor"
        Height="520"
        Width="760"
        MinHeight="420"
        MinWidth="640"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource CardBrush}"
                Padding="16"
                CornerRadius="8"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Current Status"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock x:Name="CurrentStatusText"
                           Margin="0,8,0,0"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"/>
                <TextBlock x:Name="AcStatusText"
                           Margin="0,6,0,0"
                           Foreground="{StaticResource MutedBrush}"/>
                <TextBlock x:Name="TimeRemainingText"
                           Margin="0,4,0,0"
                           Foreground="{StaticResource MutedBrush}"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="1"
                   Text="History (last 24 hours)"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8"
                   Foreground="{StaticResource TextBrush}"/>

        <DataGrid x:Name="HistoryGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  Background="{StaticResource CardBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time (UTC)" Binding="{Binding TimestampUtc, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="160"/>
                <DataGridTextColumn Header="Battery" Binding="{Binding BatteryName}" Width="140"/>
                <DataGridTextColumn Header="Charge %" Binding="{Binding ChargePercent}" Width="90"/>
                <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="110"/>
                <DataGridTextColumn Header="AC" Binding="{Binding IsAcConnected}" Width="60"/>
                <DataGridTextColumn Header="Time Left" Binding="{Binding TimeRemainingDisplay}" Width="100"/>
                <DataGridTextColumn Header="Device ID" Binding="{Binding DeviceId}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Refresh"
                    Width="100"
                    Margin="0,0,8,0"
                    Click="RefreshButton_Click"/>
            <Button Content="Close"
                    Width="100"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
