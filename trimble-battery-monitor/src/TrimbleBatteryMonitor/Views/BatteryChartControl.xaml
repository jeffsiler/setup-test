<UserControl x:Class="TrimbleBatteryMonitor.Views.BatteryChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="180">
    <Border Background="{StaticResource CardBrush}"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Charge % over time"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"
                       Foreground="{StaticResource TextBrush}"/>

            <Canvas x:Name="ChartCanvas"
                    Grid.Row="1"
                    ClipToBounds="True"
                    Background="#FAFAFA"/>
        </Grid>
    </Border>
</UserControl>
